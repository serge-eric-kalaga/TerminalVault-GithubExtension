{
  "name": "terminalvault-pro",
  "publisher": "KALAGANonga-WendSergeEric",
  "icon": "resources/logo.png",
  "displayName": "Terminal Vault Pro",
  "description": "Store, organize and quickly access your terminal commands directly from VS Code",
  "version": "0.1.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/serge-eric-kalaga/TerminalVault-GithubExtension"
  },
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other",
    "Snippets"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "terminal-vault",
          "title": "Terminal Vault",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "terminal-vault": [
        {
          "id": "terminalVaultGroups",
          "name": "Commands"
        },
        {
          "id": "terminalVaultFavorites",
          "name": "Favorites"
        }
      ]
    },
    "commands": [
      {
        "command": "terminal-vault.openPanel",
        "title": "Terminal Vault: Open Panel",
        "icon": "$(window)"
      },
      {
        "command": "terminal-vault.palette",
        "title": "Terminal Vault: Quick Palette",
        "icon": "$(zap)"
      },
      {
        "command": "terminal-vault.search",
        "title": "Terminal Vault: Search Commands"
      },
      {
        "command": "terminal-vault.addCommand",
        "title": "Terminal Vault: Add Command",
        "icon": "$(add)"
      },
      {
        "command": "terminal-vault.saveClipboardCommand",
        "title": "Terminal Vault: Save Copied Terminal Command",
        "icon": "$(clippy)"
      },
      {
        "command": "terminal-vault.saveTerminalSelection",
        "title": "Terminal Vault: Save Selected Terminal Command",
        "icon": "$(save)"
      },
      {
        "command": "terminal-vault.login",
        "title": "Terminal Vault: Login / Connect"
      },
      {
        "command": "terminal-vault.logout",
        "title": "Terminal Vault: Logout / Disconnect"
      },
      {
        "command": "terminal-vault.refresh",
        "title": "Terminal Vault: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "terminal-vault.copyCommand",
        "title": "Copy to Clipboard",
        "icon": "$(copy)"
      },
      {
        "command": "terminal-vault.runInTerminal",
        "title": "Run in Terminal",
        "icon": "$(terminal-bash)"
      },
      {
        "command": "terminal-vault.insertAtCursor",
        "title": "Insert at Cursor",
        "icon": "$(insert)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "terminal-vault.refresh",
          "when": "view == terminalVaultGroups",
          "group": "navigation@1"
        },
        {
          "command": "terminal-vault.palette",
          "when": "view == terminalVaultGroups",
          "group": "navigation@2"
        },
        {
          "command": "terminal-vault.openPanel",
          "when": "view == terminalVaultGroups",
          "group": "navigation@3"
        },
        {
          "command": "terminal-vault.saveClipboardCommand",
          "when": "view == terminalVaultGroups",
          "group": "navigation@4"
        }
      ],
      "terminal/context": [
        {
          "command": "terminal-vault.saveTerminalSelection",
          "when": "terminalTextSelected",
          "group": "3_terminalVault@1"
        },
        {
          "command": "terminal-vault.saveClipboardCommand",
          "when": "!terminalTextSelected",
          "group": "3_terminalVault@2"
        }
      ],
      "view/item/context": [
        {
          "command": "terminal-vault.copyCommand",
          "when": "viewItem == command",
          "group": "inline@1"
        },
        {
          "command": "terminal-vault.runInTerminal",
          "when": "viewItem == command",
          "group": "inline@2"
        },
        {
          "command": "terminal-vault.insertAtCursor",
          "when": "viewItem == command",
          "group": "inline@3"
        }
      ]
    },
    "keybindings": [
      {
        "command": "terminal-vault.palette",
        "key": "ctrl+shift+;",
        "mac": "cmd+shift+;"
      },
      {
        "command": "terminal-vault.search",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k"
      },
      {
        "command": "terminal-vault.saveClipboardCommand",
        "key": "ctrl+shift+alt+s",
        "mac": "cmd+shift+alt+s",
        "when": "terminalFocus || terminalTextSelected"
      }
    ],
    "configuration": {
      "title": "Terminal Vault",
      "properties": {
        "terminalVault.storageMode": {
          "type": "string",
          "enum": [
            "local",
            "github-gist"
          ],
          "enumDescriptions": [
            "Store commands locally in VS Code's global storage (JSON file)",
            "Sync commands with a GitHub Gist (requires a Personal Access Token)"
          ],
          "default": "local",
          "description": "Where to store your commands"
        },
        "terminalVault.githubGistId": {
          "type": "string",
          "default": "",
          "description": "GitHub Gist ID to sync with (leave empty to create a new one on first sync)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "bundle": "esbuild extension.js --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "bundle:watch": "npm run bundle -- --watch",
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.3"
  },
  "dependencies": {
    "@vscode/vsce": "^3.9.1"
  }
}